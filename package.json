{
  "name": "@cypherx/chat-ui",
  "version": "0.2.0",
  "description": "Production-ready chat UI components for streaming AI interfaces. SSE support, session management, action indicators, and more.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/styles.css"
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "postbuild": "npx @tailwindcss/cli -i src/styles/globals.css -o dist/styles.css",
    "prepare": "npm run build",
    "dev": "tsup --watch",
    "demo": "vite",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "lucide-react": ">=0.400.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "lucide-react": {
      "optional": false
    }
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "postcss": "^8.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.3"
  },
  "dependencies": {
    "clsx": "^2.1.0",
    "lucide-react": ">=0.400.0",
    "motion": "^12.0.0",
    "tailwind-merge": "^3.0.0"
  },
  "keywords": [
    "react",
    "chat",
    "ui",
    "components",
    "streaming",
    "sse",
    "ai",
    "chat-ui"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Trionic-Core/chat-ui-component-library.git"
  }
}
